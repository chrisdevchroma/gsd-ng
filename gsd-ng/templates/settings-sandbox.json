{
  "sandbox": {
    "enabled": true,
    "autoAllowBashIfSandboxed": true
  },
  "permissions": {
    "allow": [
      "Bash(node *)",
      "Bash(git *)",
      "Bash(npm *)",
      "Bash(npx *)",
      "Bash(ssh-add *)",
      "Bash(ssh-keygen *)",
      "Bash(date *)",
      "Bash(echo *)",
      "Bash(cat *)",
      "Bash(ls *)",
      "Bash(mkdir *)",
      "Bash(mktemp *)",
      "Bash(rm *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(sort *)",
      "Bash(grep *)",
      "Bash(find *)",
      "Bash(tr *)",
      "Bash(jq *)",
      "Bash(test *)",
      "Bash(touch *)",
      "Bash(chmod *)",
      "Bash(sed *)",
      "Bash(tar *)",
      "Bash(curl *)",
      "Agent(*)",
      "Edit",
      "Write",
      "Read",
      "Skill(gsd:*)",
      "WebFetch(*)",
      "WebSearch(*)"
    ],
    "deny": [
      "Read(.env)",
      "Read(.env.*)",
      "Read(**/*.pem)",
      "Read(**/*.key)",
      "Read(**/*.p12)",
      "Read(**/*.pfx)",
      "Read(**/*credential*)",
      "Read(**/*secret*)",
      "Read(**/.aws/*)",
      "Read(**/.ssh/*)",
      "Read(**/.npmrc)",
      "Read(**/.pypirc)",
      "Read(**/.kube/config)",
      "Read(**/.docker/config.json)",
      "Read(**/*token*)",
      "Edit(.env)",
      "Edit(.env.*)",
      "Edit(**/*.pem)",
      "Edit(**/*.key)",
      "Write(.env)",
      "Write(.env.*)",
      "Write(**/*.pem)",
      "Write(**/*.key)"
    ]
  }
}
