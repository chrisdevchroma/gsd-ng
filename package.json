{
  "name": "gsd-ng",
  "version": "1.0.0-dev.3",
  "description": "A meta-prompting, context engineering and spec-driven development system for Claude Code.",
  "bin": {
    "gsd-ng": "bin/install.js"
  },
  "files": [
    "bin",
    "commands",
    "gsd-ng",
    "agents",
    "hooks/dist"
  ],
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "meta-prompting",
    "context-engineering",
    "spec-driven-development"
  ],
  "author": "chrisdevchroma",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chrisdevchroma/gsd-ng.git"
  },
  "homepage": "https://github.com/chrisdevchroma/gsd-ng",
  "bugs": {
    "url": "https://github.com/chrisdevchroma/gsd-ng/issues"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "devDependencies": {
    "c8": "^11.0.0",
    "esbuild": "^0.24.0",
    "prettier": "3.8.3"
  },
  "scripts": {
    "format": "prettier --write 'gsd-ng/**/*.{js,cjs}' 'bin/**/*.{js,cjs}'",
    "format:check": "prettier --check 'gsd-ng/**/*.{js,cjs}' 'bin/**/*.{js,cjs}'",
    "build:hooks": "node scripts/build-hooks.js",
    "build:tarball": "npm run build:hooks && node scripts/build-tarball.js",
    "prepublishOnly": "npm run build:hooks",
    "pretest": "npm run build:hooks",
    "test": "node scripts/run-tests.cjs",
    "test:e2e": "node --test tests/e2e/smoke.test.cjs",
    "test:coverage": "npm run build:hooks && c8 --check-coverage --lines 70 --reporter text --include 'gsd-ng/bin/lib/*.cjs' --exclude 'tests/**' --all node scripts/run-tests.cjs"
  }
}
